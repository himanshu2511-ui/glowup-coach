# ─── Glowup Coach — Frontend Environment Variables ───────────────────────────
# Copy this to .env.local for local dev (no changes needed for local)
# For production (Vercel), set these in the Vercel Dashboard under
# Project → Settings → Environment Variables

# Leave empty for local dev (Vite proxy handles /api → localhost:8000)
VITE_API_BASE_URL=

# For production (after deploying backend to Render), set to:
# VITE_API_BASE_URL=https://glowup-coach-api.onrender.com
