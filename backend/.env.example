# ─── Glowup Coach — Backend Environment Variables ────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to git.

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=glowup-change-me-in-production

# Database — SQLite for local dev, PostgreSQL for production
# Leave blank for local SQLite, or set to Supabase/Neon connection string
DATABASE_URL=

# CORS — comma-separated list of allowed frontend origins
# For production: your Vercel domain
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — Render/cloud reports dir (default: ./reports)
REPORTS_DIR=./reports
